    document.querySelectorAll('.faq-item').forEach(item => item.addEventListener('click', () => item.classList.toggle('active')));

    // Simulateurs
    document.getElementById('calcImmoBtn').onclick = () => { let P=parseFloat(document.getElementById('immoAmount').value), n=parseFloat(document.getElementById('immoYears').value)*12, r=parseFloat(document.getElementById('immoRate').value)/100/12; let M = (r===0)?P/n : P * (r * Math.pow(1+r, n)) / (Math.pow(1+r,n)-1); document.getElementById('immoResult').innerHTML = M.toFixed(2)+" € / mois"; };
    document.getElementById('calcConsoBtn').onclick = () => { let P=parseFloat(document.getElementById('consoAmount').value), n=parseFloat(document.getElementById('consoMonths').value), r=parseFloat(document.getElementById('consoRate').value)/100/12; let M = (r===0)?P/n : P * (r * Math.pow(1+r, n)) / (Math.pow(1+r,n)-1); document.getElementById('consoResult').innerHTML = M.toFixed(2)+" € / mois"; };
    setTimeout(() => { document.getElementById('calcImmoBtn').click(); document.getElementById('calcConsoBtn').click(); }, 80);

    // Menu burger
    const sidebar = document.getElementById('sidebar'), overlay = document.getElementById('overlay');
    document.getElementById('burgerBtn').onclick = () => { sidebar.classList.add('open'); overlay.classList.add('active'); };
    document.getElementById('closeSidebar').onclick = () => { sidebar.classList.remove('open'); overlay.classList.remove('active'); };
    overlay.onclick = () => { sidebar.classList.remove('open'); overlay.classList.remove('active'); };
    document.querySelectorAll('.sidebar nav a, .footer-links a').forEach(a => a.addEventListener('click', (e) => { e.preventDefault(); let nav = a.getAttribute('data-nav'); if(nav === 'contact') document.getElementById('formContact').scrollIntoView({behavior:'smooth'}); if(nav === 'credits') document.querySelector('.credit-grid').scrollIntoView({behavior:'smooth'}); if(nav === 'simulateurs') document.getElementById('simuBlock').scrollIntoView({behavior:'smooth'}); if(nav === 'why') document.getElementById('whySection').scrollIntoView({behavior:'smooth'}); if(nav === 'taeg') document.getElementById('taegSection').scrollIntoView({behavior:'smooth'}); if(nav === 'testimonials') document.getElementById('testimonialsSection').scrollIntoView({behavior:'smooth'}); if(nav === 'faq') document.getElementById('faqSection').scrollIntoView({behavior:'smooth'}); if(nav === 'newsletter') document.getElementById('newsletterSection').scrollIntoView({behavior:'smooth'}); if(nav === 'about') alert(translations[currentLang].about_text); if(nav === 'legal') alert(translations[currentLang].legal_text); sidebar.classList.remove('open'); overlay.classList.remove('active'); }));

    document.querySelectorAll('.scroll-simu').forEach(btn => btn.addEventListener('click', () => document.getElementById('simuBlock').scrollIntoView({behavior:'smooth'})));

    // Retour en haut
    const backToTop = document.getElementById('backToTop');
    window.addEventListener('scroll', () => { if (window.scrollY > 300) backToTop.classList.add('visible'); else backToTop.classList.remove('visible'); });
    backToTop.addEventListener('click', (e) => { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
    document.getElementById('logoHomeLink').addEventListener('click', (e) => { e.preventDefault(); window.scrollTo({ top: 0, behavior: 'smooth' }); });

    // Cookies
    if(localStorage.getItem('cookiesAccepted') === 'true') document.getElementById('cookieBanner').style.display = 'none';
    document.getElementById('acceptCookies').onclick = () => { localStorage.setItem('cookiesAccepted', 'true'); document.getElementById('cookieBanner').style.display = 'none'; };

    // Formulaires
    const form = document.getElementById('bankContactForm');
    const successDiv = document.getElementById('formSuccess');
    if(form) {
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerText;
            submitBtn.innerText = "Envoi...";
            submitBtn.disabled = true;
            try {
                const formData = new FormData(form);
                const response = await fetch(form.action, { method: 'POST', body: formData });
                const result = await response.json();
                if(result.success) { successDiv.style.display = 'block'; form.reset(); setTimeout(() => successDiv.style.display = 'none', 5000); }
                else alert("❌ Erreur");
            } catch(error) { alert("❌ Erreur technique"); }
            finally { submitBtn.innerText = originalText; submitBtn.disabled = false; }
        });
    }

    const newsletterForm = document.getElementById('newsletterForm');
    const newsletterSuccess = document.getElementById('newsletterSuccess');
    if(newsletterForm) {
        newsletterForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = newsletterForm.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = "Envoi...";
            btn.disabled = true;
            try {
                const formData = new FormData(newsletterForm);
                const response = await fetch(newsletterForm.action, { method: 'POST', body: formData });
                const result = await response.json();
                if(result.success) { newsletterSuccess.style.display = 'block'; newsletterForm.reset(); setTimeout(() => newsletterSuccess.style.display = 'none', 5000); }
                else alert("❌ Erreur");
            } catch(error) { alert("❌ Erreur technique"); }
            finally { btn.innerText = originalText; btn.disabled = false; }
        });
    }

    applyLanguage('fr');
</script>
</body>
</html>
